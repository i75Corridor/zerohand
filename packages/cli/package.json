{
  "name": "@zerohand/cli",
  "version": "0.1.0",
  "description": "Zerohand CLI — manage pipelines, runs, and packages from the terminal",
  "type": "module",
  "bin": {
    "zerohand": "./dist/cli.cjs"
  },
  "exports": {
    ".": "./dist/cli.cjs"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=cjs --outfile=dist/cli.cjs --banner:js=\"#!/usr/bin/env node\" --external:ws",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "@zerohand/shared": "workspace:*",
    "commander": "^13.1.0",
    "ws": "^8.18.2",
    "yaml": "^2.7.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.14",
    "esbuild": "^0.25.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.0",
    "vitest": "^3.1.1"
  }
}
