{
  "name": "@i75corridor/zerohand-mcp",
  "version": "0.1.0",
  "description": "Zerohand MCP server — expose pipelines, skills, and runs to AI assistants",
  "type": "module",
  "bin": {
    "zerohand-mcp": "./dist/mcp.cjs"
  },
  "exports": {
    ".": "./dist/mcp.cjs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/i75Corridor/zerohand.git",
    "directory": "packages/mcp"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=cjs --outfile=dist/mcp.cjs --banner:js=\"#!/usr/bin/env node\" --external:ws",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@zerohand/shared": "workspace:*",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.25.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.0",
    "vitest": "^3.1.1"
  }
}
